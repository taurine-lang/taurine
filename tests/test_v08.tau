// Taurine v0.8 Full Test

print("=== Taurine v0.8 Full Test ===\n")

// 1. Index assignment
print("1. Index assignment:")
loc arr = [1, 2, 3, 4, 5]
arr[0] = 100
print("   arr:", arr)

// 2. JSON
print("\n2. JSON:")
loc jsonStr = "{ \"name\": \"test\", \"value\": 42 }"
loc obj = json_parse(jsonStr)
print("   obj.name:", obj.name)

// 3. Range
print("\n3. Range:")
for i in 1..6 {
    print("   i =", i)
}

// 4. Nil-safe operator
print("\n4. Nil-safe operator:")
loc nilObj = nil
print("   nilObj?.prop:", nilObj?.prop)
loc tableObj = { name = "test" }
print("   tableObj?.name:", tableObj?.name)

// 5. Default parameters
print("\n5. Default parameters:")
function greet(name, greeting = "Hello") {
    print("   " + greeting + ", " + name + "!")
}
greet("World")
greet("Taurine", "Hi")

// 6. Table methods
print("\n6. Table methods:")
loc counter = { count = 0 }
function increment(self, amount) {
    self.count = self.count + amount
}
increment(counter, 5)
print("   counter.count:", counter.count)

// 7. Crypto
print("\n7. Crypto:")
import "std/crypto.tau" as crypto
print("   md5('hello'):", crypto.md5("hello"))
print("   sha256('hello'):", crypto.sha256("hello"))
print("   uuid():", crypto.uuid())

// 8. Date
print("\n8. Date:")
import "std/date.tau" as date
loc now = date.now()
print("   formatted:", date.format(now, "%Y-%m-%d"))

// 9. Regex
print("\n9. Regex:")
import "std/regex.tau" as regex
loc pattern = regex.compile("\\d+")
print("   pattern:match('abc123'):", pattern:match("abc123"))

// 10. Array
print("\n10. Array:")
import "std/array.tau" as array
print("   array.len([1,2,3]):", array.len([1, 2, 3]))

print("\n=== All tests passed ===")
