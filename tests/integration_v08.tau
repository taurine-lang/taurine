// Integration test for Taurine v0.8
// Helper function
function assert(condition, message) {
    if not condition {
        throw "ASSERTION FAILED: " + message
    }
}

print("=== Integration Test v0.8 ===\n")

// Test 1: Index assignment
loc arr = [1, 2, 3]
arr[0] = 100
assert(arr[0] == 100, "Index assignment failed")
print("✓ Index assignment")

// Test 2: JSON parse
loc json = json_parse("{ \"a\": 1, \"b\": 2 }")
assert(json.a == 1, "JSON parse failed")
print("✓ JSON parse")

// Test 3: JSON stringify
loc obj = { x = 10 }
loc jsonStr = json_stringify(obj)
assert(jsonStr != nil, "JSON stringify failed")
print("✓ JSON stringify")

// Test 4: Range
loc sum = 0
for i in 1..6 {
    sum = sum + i
}
assert(sum == 15, "Range failed")
print("✓ Range")

// Test 5: Nil-safe operator
loc nilObj = nil
assert(nilObj?.prop == nil, "Nil-safe failed")
loc tableObj = { name = "test" }
assert(tableObj?.name == "test", "Nil-safe failed")
print("✓ Nil-safe operator")

// Test 6: Function literal
loc fn = function(a, b) { return a + b }
print("✓ Function literal")

// Test 7: Crypto md5
loc hash = crypto_md5("hello")
assert(hash == "5d41402abc4b2a76b9719d911017c592", "MD5 failed")
print("✓ Crypto MD5")

// Test 8: Crypto sha256
loc hash256 = crypto_sha256("hello")
assert(hash256 == "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824", "SHA256 failed")
print("✓ Crypto SHA256")

// Test 9: Crypto base64
loc encoded = crypto_base64_encode("hello")
assert(encoded == "aGVsbG8=", "Base64 encode failed")
print("✓ Crypto Base64")

// Test 10: Crypto uuid
loc uuid = crypto_uuid()
assert(uuid != nil and #uuid > 0, "UUID failed")
print("✓ Crypto UUID")

// Test 11: Date
loc now = date_now()
assert(now != nil, "Date now failed")
print("✓ Date now")

// Test 12: Date format
loc formatted = date_format(now, "%Y-%m-%d")
assert(formatted != nil and #formatted > 0, "Date format failed")
print("✓ Date format")

// Test 13: Regex match
assert(regex_match("\\d+", "abc123"), "Regex match failed")
assert(not regex_match("\\d+", "abc"), "Regex match failed")
print("✓ Regex match")

// Test 14: Regex find
loc m = regex_find("\\d+", "abc123")
assert(m != nil, "Regex find failed")
assert(m.text == "123", "Regex find failed")
print("✓ Regex find")

// Test 15: Regex replace
loc replaced = regex_replace("\\d+", "abc123", "X")
assert(replaced == "abcX", "Regex replace failed")
print("✓ Regex replace")

// Test 16: Import JSON module
import "std/json.tau" as json
loc encoded2 = json.encode({ test = 123 })
assert(encoded2 != nil, "JSON module failed")
print("✓ Import module")

// Test 17: String concatenation with numbers
loc str = "Value: " + 42
assert(str == "Value: 42", "String concat failed")
print("✓ String concatenation")

// Test 18: Array built-in functions
loc arr2 = [1, 2, 3]
assert(#arr2 == 3, "Array length failed")
print("✓ Array length operator")

// Test 19: Table operations
loc t = { a = 1, b = 2 }
assert(t.a == 1, "Table get failed")
t.a = 100
assert(t.a == 100, "Table set failed")
print("✓ Table operations")

// Test 20: Control flow
loc result = ""
if true {
    result = "ok"
}
assert(result == "ok", "If statement failed")
print("✓ Control flow")

print("\n=== All 20 integration tests passed! ===")
