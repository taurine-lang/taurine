// test_multi_return.tau

print("=== Test multi-return ===\n")

// Test 1: Function with multiple return
function divmod(a, b) {
    return a / b, a % b
}

loc result = divmod(10, 3)
print("Test 1: divmod(10, 3) =", result)

// Test 2: Destructure from function
loc {q, r} = divmod(10, 3)
print("Test 2: q =", q, ", r =", r)

// Test 3: Destructure from array
loc arr = [100, 200, 300]
loc {x, y, z} = arr
print("Test 3: x =", x, ", y =", y, ", z =", z)

// Test 4: Destructure with fewer variables
loc {a, b} = [1, 2, 3, 4]
print("Test 4: a =", a, ", b =", b)

// Test 5: Destructure with more variables
loc {p, q, r, s} = [10, 20]
print("Test 5: p =", p, ", q =", q, ", r =", r, ", s =", s)

print("\n=== All multi-return tests passed! ===")
