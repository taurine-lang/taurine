// test_break_continue.tau

print("=== Test break/continue ===\n")

// Test 1: break in while
print("Test 1: break in while")
loc i = 0
while i < 10 {
    i = i + 1
    if i == 5 {
        break
    }
    print("  i =", i)
}
print("  Final i:", i)

// Test 2: continue in while
print("\nTest 2: continue in while")
loc j = 0
loc sum = 0
while j < 5 {
    j = j + 1
    if j == 3 {
        continue
    }
    sum = sum + j
}
print("  sum (without 3):", sum)

// Test 3: break in for-in
print("\nTest 3: break in for-in")
for i in 1..10 {
    if i == 5 {
        break
    }
    print("  i =", i)
}

// Test 4: continue in for-in
print("\nTest 4: continue in for-in")
for i in 1..6 {
    if i == 3 {
        continue
    }
    print("  i =", i)
}

print("\n=== All break/continue tests passed! ===")
