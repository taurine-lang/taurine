// test_v06_full.tau — Полные тесты для v0.6

// 1. Тест присваивания по индексу массива
print("=== Тест 1: Присваивание по индексу ===")
loc arr = [1, 2, 3, 4, 5]
print("До:", arr)
arr[0] = 100
print("После arr[0] = 100:", arr)
arr[2] = 999
print("После arr[2] = 999:", arr)

// 2. Тест JSON parse
print("\n=== Тест 2: JSON parse ===")
loc json_str = "{ \"name\": \"ffsonDev\", \"age\": 25, \"skills\": [\"Rust\", \"Lua\", \"Taurine\"] }"
print("JSON строка:", json_str)
loc obj = json_parse(json_str)
print("Распарсенный объект:", obj)
print("name:", obj.name)
print("age:", obj.age)
print("skills:", obj.skills)

// 3. Тест JSON stringify
print("\n=== Тест 3: JSON stringify ===")
loc data = { name = "test", value = 42 }
print("Объект:", data)
loc json_out = json_stringify(data)
print("JSON строка:", json_out)

// 4. Тест Range в for-in
print("\n=== Тест 4: Range в for-in ===")
print("Счёт от 1 до 5:")
for i in 1..6 {
    print("  i =", i)
}

// 5. Тест std/json.tau
print("\n=== Тест 5: std/json.tau ===")
import "std/json.tau" as json
loc test_obj = { x = 10, y = 20 }
loc encoded = json.encode(test_obj)
print("encoded:", encoded)
loc decoded = json.decode(encoded)
print("decoded:", decoded)
print("decoded.x:", decoded.x)

print("\n=== Все тесты завершены ===")
