// std/test.tau — Тестовый фреймворк

let _tests = []
let _current_suite = ""

function describe(name, fn) {
    _current_suite = name
    fn()
}

function it(name, fn) {
    io_arraypush(_tests, {
        suite: _current_suite,
        name: name,
        fn: fn
    })
}

function run_tests() {
    let passed = 0
    let failed = 0
    
    print(f"\n🧪 Running {#_tests} test(s)...\n")
    
    for test in _tests {
        try {
            test.fn()
            print(f"  ✓ {test.suite}: {test.name}")
            passed = passed + 1
        } catch (err) {
            print(f"  ✗ {test.suite}: {test.name}")
            print(f"    Error: {err}")
            failed = failed + 1
        }
    }
    
    print(f"\n=== Results: {passed} passed, {failed} failed ===\n")
    
    if failed > 0 {
        throw(f"{failed} test(s) failed")
    }
}

function reset_tests() {
    _tests = []
    _current_suite = ""
}
