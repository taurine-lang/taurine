// std/array.tau — Array utility module
// Provides functional and imperative array operations

// ============================================================================
// Functional API (recommended)
// ============================================================================

function len(arr) {
    return #arr
}

function push(arr, value) {
    io_arraypush(arr, value)
}

function pop(arr) {
    return io_arraypop(arr)
}

function concat(arr1, arr2) {
    return io_arrayconcat(arr1, arr2)
}

function reverse(arr) {
    io_arrayreverse(arr)
}

function clear(arr) {
    io_arrayclear(arr)
}

function get(arr, index) {
    return io_arrayget(arr, index)
}

function set(arr, index, value) {
    io_arrayset(arr, index, value)
}

function slice(arr, start, length) {
    let result = []
    let i = start
    while i < start + length and i < #arr {
        push(result, arr[i])
        i = i + 1
    }
    return result
}

function forEach(arr, fn) {
    let i = 0
    while i < #arr {
        fn(io_arrayget(arr, i))
        i = i + 1
    }
}

function map(arr, fn) {
    let result = []
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        push(result, fn(io_arrayget(arr, i)))
        i = i + 1
    }
    return result
}

function filter(arr, fn) {
    let result = []
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        let item = io_arrayget(arr, i)
        if fn(item) {
            push(result, item)
        }
        i = i + 1
    }
    return result
}

function find(arr, fn) {
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        let item = io_arrayget(arr, i)
        if fn(item) {
            return item
        }
        i = i + 1
    }
    return nil
}

function includes(arr, value) {
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        if io_arrayget(arr, i) == value {
            return true
        }
        i = i + 1
    }
    return false
}

function indexOf(arr, value) {
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        if io_arrayget(arr, i) == value {
            return i
        }
        i = i + 1
    }
    return -1
}

function join(arr, delimiter) {
    let result = ""
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        if i > 0 {
            result = result + delimiter
        }
        result = result + tostring(io_arrayget(arr, i))
        i = i + 1
    }
    return result
}

function reduce(arr, fn, initial) {
    let result = initial
    let i = 0
    let len = io_arraylen(arr)
    while i < len {
        result = fn(result, io_arrayget(arr, i))
        i = i + 1
    }
    return result
}